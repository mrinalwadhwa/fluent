#!/usr/bin/env bash
# test-run — Verify operational behaviors of the factory command.
#
# Tests the factory's run lifecycle mechanics by creating a temporary git
# project, calling actual factory functions against it, and asserting the
# expected file system state.
#
# Sources the factory script in library mode (FACTORY_LIB=1) to call
# resolve_run_id and setup_run_worktree directly — testing the real
# implementation, not a copy of the logic.
#
# Covers:
#   - Run-id resolution (--run-id, FACTORY_RUN_ID env, active-run, scan)
#   - Worktree creation and run state copying
#   - Worktree from non-main branch
#   - Status display
#
# Usage:
#   tests/test-run

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
FACTORY="${PROJECT_DIR}/scripts/factory"

PASS=0
FAIL=0
ERRORS=""

# Source factory functions (library mode — no dispatch)
FACTORY_LIB=1 . "$FACTORY"

# -------------------------------------------------------------------------
# Helpers
# -------------------------------------------------------------------------

setup_test_project() {
  TEST_DIR="$(mktemp -d -t factory-test-XXXXXX)"
  mkdir -p "${TEST_DIR}/main"
  cd "${TEST_DIR}/main"
  # Disable signing and use test identity
  git init -b main > /dev/null 2>&1
  git config commit.gpgsign false
  git config user.email "test@test"
  git config user.name "test"
  echo "test" > README.md
  git add . && git commit -m "init" > /dev/null 2>&1
}

cleanup_test_project() {
  cd /
  # Remove worktrees first
  if [ -d "${TEST_DIR}/main/.git" ]; then
    git -C "${TEST_DIR}/main" worktree list --porcelain 2>/dev/null | \
      grep '^worktree ' | awk '{print $2}' | \
      grep -v "${TEST_DIR}/main" | while read -r wt; do
      git -C "${TEST_DIR}/main" worktree remove --force "$wt" 2>/dev/null || true
    done
  fi
  rm -rf "$TEST_DIR"
}

assert_file_exists() {
  if [ ! -f "$1" ]; then
    printf '    FAIL: expected file %s to exist\n' "$1"
    return 1
  fi
}

assert_file_contains() {
  if [ ! -f "$1" ]; then
    printf '    FAIL: file %s does not exist\n' "$1"
    return 1
  fi
  CONTENT="$(cat "$1")"
  if [ "$CONTENT" != "$2" ]; then
    printf '    FAIL: %s contains "%s", expected "%s"\n' "$1" "$CONTENT" "$2"
    return 1
  fi
}

assert_dir_exists() {
  if [ ! -d "$1" ]; then
    printf '    FAIL: expected directory %s to exist\n' "$1"
    return 1
  fi
}

run_test() {
  TEST_NAME="$1"
  printf '  %s ... ' "$TEST_NAME"
  if ( eval "$2" ) 2>&1; then
    printf 'PASS\n'
    PASS=$((PASS + 1))
  else
    printf '\n'
    FAIL=$((FAIL + 1))
    ERRORS="${ERRORS}\n  - ${TEST_NAME}"
  fi
}

# -------------------------------------------------------------------------
# Tests
# -------------------------------------------------------------------------

test_resolve_run_id_via_active_run() {
  setup_test_project

  mkdir -p ".factory/runs/run-active"
  printf 'planned' > ".factory/runs/run-active/status"
  printf 'Brief' > ".factory/runs/run-active/brief.md"
  printf 'run-active' > ".factory/active-run"

  # Call the real resolve_run_id function
  RUN_ID=""
  resolve_run_id "$(pwd)"

  RESULT=0
  [ "$RUN_ID" = "run-active" ] || { printf '    FAIL: RUN_ID=%s, expected run-active\n' "$RUN_ID"; RESULT=1; }
  [ -d "$RUN_DIR" ] || { printf '    FAIL: RUN_DIR not set\n'; RESULT=1; }

  cleanup_test_project
  return $RESULT
}

test_resolve_run_id_via_env() {
  setup_test_project

  mkdir -p ".factory/runs/run-env"
  printf 'planned' > ".factory/runs/run-env/status"
  printf 'Brief' > ".factory/runs/run-env/brief.md"

  # No active-run file, but FACTORY_RUN_ID is set
  RUN_ID=""
  FACTORY_RUN_ID="run-env" resolve_run_id "$(pwd)"

  RESULT=0
  [ "$RUN_ID" = "run-env" ] || { printf '    FAIL: RUN_ID=%s, expected run-env\n' "$RUN_ID"; RESULT=1; }

  cleanup_test_project
  return $RESULT
}

test_resolve_run_id_via_scan() {
  setup_test_project

  mkdir -p ".factory/runs/run-scan"
  printf 'planned' > ".factory/runs/run-scan/status"
  printf 'Brief' > ".factory/runs/run-scan/brief.md"
  # No active-run, no env var — should scan and find it

  RUN_ID=""
  resolve_run_id "$(pwd)"

  RESULT=0
  [ "$RUN_ID" = "run-scan" ] || { printf '    FAIL: RUN_ID=%s, expected run-scan\n' "$RUN_ID"; RESULT=1; }

  cleanup_test_project
  return $RESULT
}

test_resolve_run_id_flag_overrides_active_run() {
  setup_test_project

  mkdir -p ".factory/runs/run-a" ".factory/runs/run-b"
  printf 'planned' > ".factory/runs/run-a/status"
  printf 'planned' > ".factory/runs/run-b/status"
  printf 'A' > ".factory/runs/run-a/brief.md"
  printf 'B' > ".factory/runs/run-b/brief.md"
  printf 'run-a' > ".factory/active-run"

  # --run-id flag (simulated by setting RUN_ID before calling)
  RUN_ID="run-b"
  resolve_run_id "$(pwd)"

  RESULT=0
  [ "$RUN_ID" = "run-b" ] || { printf '    FAIL: RUN_ID=%s, expected run-b\n' "$RUN_ID"; RESULT=1; }

  cleanup_test_project
  return $RESULT
}

test_setup_run_worktree() {
  setup_test_project

  RUN_ID="test-wt-run"
  mkdir -p ".factory/runs/${RUN_ID}"
  printf 'Test brief' > ".factory/runs/${RUN_ID}/brief.md"
  printf 'planned' > ".factory/runs/${RUN_ID}/status"

  RUN_DIR="$(pwd)/.factory/runs/${RUN_ID}"

  # Call the real setup_run_worktree function
  setup_run_worktree "$(pwd)"

  RESULT=0
  assert_dir_exists "$WORKTREE_DIR" || RESULT=1
  assert_file_contains "${WORKTREE_DIR}/.factory/active-run" "$RUN_ID" || RESULT=1
  assert_file_exists "${WORKTREE_DIR}/.factory/runs/${RUN_ID}/brief.md" || RESULT=1
  assert_file_contains "${WORKTREE_DIR}/.factory/runs/${RUN_ID}/status" "planned" || RESULT=1
  assert_file_exists "${RUN_DIR}/source-branch" || RESULT=1
  assert_file_contains "${RUN_DIR}/source-branch" "main" || RESULT=1
  assert_file_exists "${RUN_DIR}/worktree" || RESULT=1

  cleanup_test_project
  return $RESULT
}

test_setup_run_worktree_from_branch() {
  setup_test_project

  # Create a feature branch with extra content
  git checkout -b feature-x > /dev/null 2>&1
  echo "feature work" > feature.txt
  git add . && git commit -m "feature" > /dev/null 2>&1

  RUN_ID="test-branch-run"
  mkdir -p ".factory/runs/${RUN_ID}"
  printf 'Branch brief' > ".factory/runs/${RUN_ID}/brief.md"
  printf 'planned' > ".factory/runs/${RUN_ID}/status"

  RUN_DIR="$(pwd)/.factory/runs/${RUN_ID}"

  # Call from the feature branch
  setup_run_worktree "$(pwd)"

  RESULT=0
  assert_file_exists "${WORKTREE_DIR}/feature.txt" || RESULT=1
  assert_file_contains "${RUN_DIR}/source-branch" "feature-x" || RESULT=1

  cleanup_test_project
  return $RESULT
}

test_reviewer_artifact_resolves_to_worktree() {
  setup_test_project
  ORIGINAL_ROOT="$(pwd)"

  RUN_ID="test-review-path"
  mkdir -p ".factory/runs/${RUN_ID}"
  printf 'Brief' > ".factory/runs/${RUN_ID}/brief.md"
  printf 'planned' > ".factory/runs/${RUN_ID}/status"
  RUN_DIR="${ORIGINAL_ROOT}/.factory/runs/${RUN_ID}"

  setup_run_worktree "$ORIGINAL_ROOT"
  WORKTREE_RUN_DIR="${WORKTREE_DIR}/.factory/runs/${RUN_ID}"
  mkdir -p "${WORKTREE_RUN_DIR}/reviews"

  # Mock claude: writes review file at relative path (simulates agent behavior).
  # The real agent is told to write to .factory/runs/RUN_ID/reviews/review-NAME.md.
  # Without the cd fix in run_single_reviewer, this resolves to the original
  # project root instead of the worktree, and the artifact check fails.
  claude() {
    mkdir -p ".factory/runs/test-review-path/reviews"
    printf 'Verdict: pass\n\nLooks good.' > ".factory/runs/test-review-path/reviews/review-mock.md"
  }

  RESULT_FILE="$(mktemp)"
  run_single_reviewer "mock" "system" "prompt" "$WORKTREE_RUN_DIR" "$RESULT_FILE"

  RESULT=0
  assert_file_exists "${WORKTREE_RUN_DIR}/reviews/review-mock.md" || RESULT=1
  [ "$(cat "$RESULT_FILE")" = "pass" ] || { printf '    FAIL: verdict not extracted\n'; RESULT=1; }

  rm -f "$RESULT_FILE"
  cleanup_test_project
  return $RESULT
}

test_status_display() {
  setup_test_project

  mkdir -p ".factory/runs/run-001" ".factory/runs/run-002"
  printf 'planned' > ".factory/runs/run-001/status"
  printf 'complete' > ".factory/runs/run-002/status"
  printf 'First run' > ".factory/runs/run-001/brief.md"
  printf 'Second run' > ".factory/runs/run-002/brief.md"
  printf 'local' > ".factory/runs/run-001/backend"
  printf 'local' > ".factory/runs/run-002/backend"

  OUTPUT="$(cmd_status "$(pwd)" 2>&1 || true)"

  RESULT=0
  echo "$OUTPUT" | grep -q "run-001" || { printf '    FAIL: run-001 not in output\n'; RESULT=1; }
  echo "$OUTPUT" | grep -q "run-002" || { printf '    FAIL: run-002 not in output\n'; RESULT=1; }
  echo "$OUTPUT" | grep -q "planned" || { printf '    FAIL: planned not in output\n'; RESULT=1; }
  echo "$OUTPUT" | grep -q "complete" || { printf '    FAIL: complete not in output\n'; RESULT=1; }

  cleanup_test_project
  return $RESULT
}

# -------------------------------------------------------------------------
# Run all tests
# -------------------------------------------------------------------------

printf 'test-run\n\n'

run_test "resolve run-id via active-run" test_resolve_run_id_via_active_run
run_test "resolve run-id via env var" test_resolve_run_id_via_env
run_test "resolve run-id via scan" test_resolve_run_id_via_scan
run_test "resolve run-id flag overrides active-run" test_resolve_run_id_flag_overrides_active_run
run_test "setup_run_worktree creates worktree with state" test_setup_run_worktree
run_test "setup_run_worktree from non-main branch" test_setup_run_worktree_from_branch
run_test "reviewer artifact resolves to worktree" test_reviewer_artifact_resolves_to_worktree
run_test "status display shows all runs" test_status_display

printf '\n  %d passed, %d failed\n' "$PASS" "$FAIL"

if [ "$FAIL" -gt 0 ]; then
  printf '\n  Failures:%b\n' "$ERRORS"
  exit 1
fi
