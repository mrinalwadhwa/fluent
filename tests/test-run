#!/usr/bin/env bash
# test-run — Verify run lifecycle behavior through the Rust test suite.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

cd "$PROJECT_DIR"

for test_name in \
  worktree_copies_run_state \
  worktree_branches_from_current_branch \
  run_resolves_via_active_run_pointer \
  run_session_loop_stops_on_complete \
  run_session_loop_stops_on_needs_user \
  run_session_loop_restarts_on_executing
do
  cargo test --test binary "$test_name"
done
