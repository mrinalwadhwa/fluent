# OS
.DS_Store

# Environment
.env
.env.*
!.env.example

# Python
__pycache__/

# Scratch
.scratch/

# Dependencies
node_modules/

# Fluent — working state, except expertise, hooks, Dockerfile, and tester
# contract files. Observations stay local (a working backlog), not committed.
.fluent/*
!.fluent/expertise/
!.fluent/hooks/
!.fluent/Dockerfile
!.fluent/tester.yaml
!.fluent/extract-tester-results


# Test output (per-case logs, never committed)
tests/output/

# Added by cargo
/target
/.cargo-home
/.cargo
.cargo-home/
cargo-home/
