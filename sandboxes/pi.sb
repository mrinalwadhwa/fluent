;; ==========================================================================
;; Pi (pi.dev) -- profile-specific Seatbelt rules
;; ==========================================================================
;; Concatenated after common.sb by Factory when launching Pi.
;;
;; NOTE: No (allow iokit*) -- Pi is a CLI tool, not a GUI app.
;; It does not need Metal GPU enumeration or any IOKit services.
;;
;; Pi talks to the local vllm-mlx server at 127.0.0.1:8000. No external
;; API allowlist is needed.
;; ==========================================================================

;; Pi configuration, extensions, and session data.
(allow file-read*  (subpath "_HOME_/.pi"))
(allow file-write* (subpath "_HOME_/.pi/agent/sessions"))
