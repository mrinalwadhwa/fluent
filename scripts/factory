#!/usr/bin/env sh
# factory — run coding agents inside a macOS Seatbelt sandbox with
# session continuity.
#
# Subcommands:
#   factory                Launch an interactive sandboxed agent session
#   factory run [OPTIONS]  Autonomous session loop (agent works unattended)
#   factory status         Show active run state
#   factory resume [ID]    Restart a paused or failed run
#
# The sandbox and credential infrastructure is forked from the
# sandboxed-claude-code script in the skills repo.

set -e

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

FACTORY_CONFIG="${FACTORY_CONFIG:-$HOME/.config/factory}"
SANDBOX_DIR="${SANDBOX_DIR:-$HOME/.config/sandbox}"
PROFILE_TEMPLATE="${FACTORY_CONFIG}/claude-code.sb"
COMMON_PROFILE="${FACTORY_CONFIG}/common.sb"
PROXY_SCRIPT="${SANDBOX_DIR}/proxy.py"
PROXY_PORT="${PROXY_PORT:-9121}"

LOG_DIR="${HOME}/.local/state/factory"
LOG_FILE="${LOG_DIR}/factory.log"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

die() {
  printf 'factory: %s\n' "$1" >&2
  exit 1
}

PROXY_PID=""
RENDERED_PROFILE=""
WATCHDOG_PID=""

cleanup() {
  if [ -n "$PROXY_PID" ]; then
    kill "$PROXY_PID" 2>/dev/null || true
  fi
  if [ -n "$WATCHDOG_PID" ]; then
    kill "$WATCHDOG_PID" 2>/dev/null || true
  fi
  if [ -n "$RENDERED_PROFILE" ] && [ -f "$RENDERED_PROFILE" ]; then
    rm -f "$RENDERED_PROFILE"
  fi
}

# ---------------------------------------------------------------------------
# Prompts — loaded from prompts/ directory
# ---------------------------------------------------------------------------

if [ -z "${PROMPTS_DIR:-}" ]; then
  PROMPTS_DIR="$(cd "$(dirname "$0")/../prompts" && pwd)"
fi

FACTORY_SYSTEM_PROMPT="$(cat "${PROMPTS_DIR}/author.md")"
FACTORY_MODEL="${FACTORY_MODEL:-claude-opus-4-6}"

# Extract a named section from a prompt file.
# Usage: prompt_section <file> <section-name>
# Sections are delimited by [section-name] markers.
prompt_section() {
  awk -v section="$2" '
    /^\[.*\]$/ { in_section = ($0 == "[" section "]"); next }
    in_section
  ' "$1"
}

# ---------------------------------------------------------------------------
# Sandbox setup (shared across subcommands)
# ---------------------------------------------------------------------------

setup_sandbox() {
  SANDBOX_ROOT="${SANDBOX_ROOT:-$(pwd)}"
  SANDBOX_ROOT="$(cd "$SANDBOX_ROOT" && pwd)"

  [ -f "$COMMON_PROFILE" ] || die "Common profile not found: $COMMON_PROFILE"
  [ -f "$PROFILE_TEMPLATE" ] || die "Seatbelt profile not found: $PROFILE_TEMPLATE"
  command -v sandbox-exec >/dev/null 2>&1 || die "sandbox-exec not found (macOS only)"
  command -v claude       >/dev/null 2>&1 || die "claude not found in PATH"

  # Render the profile
  RENDERED_PROFILE="$(mktemp /tmp/factory-sandbox-XXXXXX)"
  cat "$COMMON_PROFILE" "$PROFILE_TEMPLATE" | sed \
    -e "s|_HOME_|$HOME|g" \
    -e "s|_SANDBOX_ROOT_|$SANDBOX_ROOT|g" \
    > "$RENDERED_PROFILE"

  trap cleanup EXIT INT TERM
}

# ---------------------------------------------------------------------------
# Credential injection (runs OUTSIDE the sandbox)
# ---------------------------------------------------------------------------

inject_credentials() {
  keychain_inet() {
    security find-internet-password -s "$1" -a "$2" -w 2>/dev/null || true
  }

  # OAuth token
  if [ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
    CRED_JSON="$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null || true)"
    if [ -n "$CRED_JSON" ]; then
      TOKEN="$(printf '%s' "$CRED_JSON" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('claudeAiOauth', {}).get('accessToken', ''))
except Exception:
    pass
" 2>/dev/null || true)"
      if [ -n "$TOKEN" ]; then
        export CLAUDE_CODE_OAUTH_TOKEN="$TOKEN"
        printf '  OAuth token injected from Keychain\n'
      fi
    fi
  fi

  # API key (skip if OAuth available)
  if [ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" ] && [ -z "${ANTHROPIC_API_KEY:-}" ]; then
    KEY="$(keychain_inet "https://api.anthropic.com" "Bearer")"
    if [ -n "$KEY" ]; then
      export ANTHROPIC_API_KEY="$KEY"
      printf '  Anthropic key injected from Keychain\n'
    fi
  fi

  # Brave Search API key
  if [ -z "${BRAVE_SEARCH_API_KEY:-}" ]; then
    KEY="$(security find-generic-password -s "zed-sandbox" -a "brave_api_key" -w 2>/dev/null || true)"
    if [ -n "$KEY" ]; then
      export BRAVE_SEARCH_API_KEY="$KEY"
      printf '  Brave Search key injected from Keychain\n'
    fi
  fi

  # AWS credentials — resolve SSO/profile to temporary STS credentials
  # so the sandboxed agent can use AWS CLI without reading ~/.aws/
  if [ -z "${AWS_ACCESS_KEY_ID:-}" ] && command -v aws >/dev/null 2>&1; then
    AWS_CREDS="$(aws configure export-credentials --format env-no-export 2>/dev/null || true)"
    if [ -n "$AWS_CREDS" ]; then
      eval "$AWS_CREDS"
      export AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN
      AWS_REGION_VAL="$(aws configure get region 2>/dev/null || true)"
      if [ -n "$AWS_REGION_VAL" ]; then
        export AWS_DEFAULT_REGION="$AWS_REGION_VAL"
      fi
      printf '  AWS credentials injected (STS temporary)\n'
    fi
  fi
}

# ---------------------------------------------------------------------------
# Git SSH signing
# ---------------------------------------------------------------------------

setup_git_signing() {
  SSH_SIGN_AGENT="${SANDBOX_DIR}/ssh-sign-agent"
  if [ -f "$SSH_SIGN_AGENT" ] && [ -x "$SSH_SIGN_AGENT" ]; then
    export GIT_CONFIG_COUNT=1
    export GIT_CONFIG_KEY_0=gpg.ssh.program
    export GIT_CONFIG_VALUE_0="$SSH_SIGN_AGENT"
    printf '  Git SSH signing routed through ssh-agent\n'
  fi
}

# ---------------------------------------------------------------------------
# Credential proxy (for non-OAuth users)
# ---------------------------------------------------------------------------

setup_proxy() {
  mkdir -p "$LOG_DIR"
  printf '\n=== factory %s  root=%s ===\n' \
    "$(date '+%Y-%m-%d %H:%M:%S')" "$SANDBOX_ROOT" >> "$LOG_FILE"

  if [ -f "$PROXY_SCRIPT" ] && [ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
    command -v python3 >/dev/null 2>&1 || die "python3 required for credential proxy"

    python3 "$PROXY_SCRIPT" --port "$PROXY_PORT" >> "$LOG_FILE" 2>&1 &
    PROXY_PID=$!

    PROXY_READY=0
    for _ in 1 2 3 4 5 6; do
      sleep 0.5
      kill -0 "$PROXY_PID" 2>/dev/null || die "Credential proxy exited unexpectedly"
      if curl -sf "http://127.0.0.1:${PROXY_PORT}/" >/dev/null 2>&1; then
        PROXY_READY=1
        break
      fi
    done
    [ "$PROXY_READY" = 1 ] || die "Credential proxy did not respond on port ${PROXY_PORT}"

    export ANTHROPIC_API_KEY="sk-ant-proxy-managed"
    export ANTHROPIC_BASE_URL="http://127.0.0.1:${PROXY_PORT}/anthropic-api"
    printf '  Credential proxy  pid=%s  port=%s\n' "$PROXY_PID" "$PROXY_PORT"
  elif [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
    printf '  OAuth token present — skipping credential proxy\n'
  else
    printf '  No proxy.py found — using direct API access\n'
  fi
}

# ---------------------------------------------------------------------------
# Agent browser daemon
# ---------------------------------------------------------------------------

setup_agent_browser() {
  if command -v agent-browser >/dev/null 2>&1; then
    printf '  Starting agent-browser daemon outside sandbox...\n'
    agent-browser open about:blank >> "$LOG_FILE" 2>&1 || true
    printf '  agent-browser daemon ready\n'

    _ab_watchdog() {
      while true; do
        sleep 3
        if [ ! -S "${HOME}/.agent-browser/default.sock" ]; then
          sleep 1
          [ -S "${HOME}/.agent-browser/default.sock" ] && continue
          agent-browser open about:blank >> "$LOG_FILE" 2>&1 || true
        fi
      done
    }
    _ab_watchdog &
    WATCHDOG_PID=$!
  fi
}

# ---------------------------------------------------------------------------
# Launch author inside sandbox
# ---------------------------------------------------------------------------

launch_author() {
  printf '  Sandbox root      %s\n\n' "$SANDBOX_ROOT"
  sandbox-exec -f "$RENDERED_PROFILE" claude \
    --append-system-prompt "$FACTORY_SYSTEM_PROMPT" \
    "$@"
}

# ---------------------------------------------------------------------------
# Subcommand: (bare) — interactive session
# ---------------------------------------------------------------------------

cmd_interactive() {
  setup_sandbox
  inject_credentials
  setup_git_signing
  setup_proxy
  setup_agent_browser

  printf '  Factory           interactive session\n'
  launch_author "$@"
}

# ---------------------------------------------------------------------------
# Run ID resolution (shared across backends)
# ---------------------------------------------------------------------------

# Resolve RUN_ID from: --run-id flag > FACTORY_RUN_ID env > active-run file > scan
resolve_run_id() {
  SEARCH_ROOT="${1:-$(pwd)}"
  FACTORY_RUNS="${SEARCH_ROOT}/.factory/runs"

  # 1. Already set via --run-id flag
  if [ -n "$RUN_ID" ]; then
    RUN_DIR="${FACTORY_RUNS}/${RUN_ID}"
    [ -d "$RUN_DIR" ] || die "Run directory not found: $RUN_DIR"
    return
  fi

  # 2. FACTORY_RUN_ID env var (Fargate passes this)
  if [ -n "${FACTORY_RUN_ID:-}" ]; then
    RUN_ID="$FACTORY_RUN_ID"
    RUN_DIR="${FACTORY_RUNS}/${RUN_ID}"
    [ -d "$RUN_DIR" ] || die "Run directory not found: $RUN_DIR"
    return
  fi

  # 3. active-run pointer
  if [ -f "${SEARCH_ROOT}/.factory/active-run" ]; then
    RUN_ID="$(cat "${SEARCH_ROOT}/.factory/active-run")"
    RUN_DIR="${FACTORY_RUNS}/${RUN_ID}"
    if [ -d "$RUN_DIR" ]; then
      return
    fi
    # Stale pointer — fall through to scan
    RUN_ID=""
  fi

  # 4. Scan for active run
  RUN_DIR=""
  if [ -d "$FACTORY_RUNS" ]; then
    for dir in "$FACTORY_RUNS"/*/; do
      [ -d "$dir" ] || continue
      if [ -f "${dir}status" ]; then
        s="$(cat "${dir}status" 2>/dev/null || true)"
        if [ "$s" = "planned" ] || [ "$s" = "executing" ]; then
          RUN_DIR="$dir"
          RUN_ID="$(basename "$dir")"
        fi
      fi
    done
  fi

  [ -n "$RUN_DIR" ] || die "No active run found. Create a brief and plan first."
}

# Create a git worktree for the run and copy run state into it.
# Sets WORKTREE_DIR to the new worktree path.
setup_run_worktree() {
  SOURCE_ROOT="$1"  # the worktree we're branching from

  # Record source branch
  SOURCE_BRANCH="$(git -C "$SOURCE_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")"
  printf '%s' "$SOURCE_BRANCH" > "${RUN_DIR}/source-branch"

  # Compute worktree path as sibling of source worktree
  PROJECT_ROOT="$(cd "$SOURCE_ROOT/.." && pwd)"
  WORKTREE_DIR="${PROJECT_ROOT}/${RUN_ID}"

  if [ -d "$WORKTREE_DIR" ]; then
    printf '  Worktree already exists: %s\n' "$WORKTREE_DIR"
  else
    printf '  Creating worktree %s from %s...\n' "$RUN_ID" "$SOURCE_BRANCH"
    if ! git -C "$SOURCE_ROOT" worktree add "${WORKTREE_DIR}" -b "$RUN_ID" 2>/dev/null; then
      # Branch exists from a previous run — reset it to current HEAD before checkout
      git -C "$SOURCE_ROOT" branch -f "$RUN_ID" HEAD
      git -C "$SOURCE_ROOT" worktree add "${WORKTREE_DIR}" "$RUN_ID"
    fi
  fi

  # Copy run state into worktree
  mkdir -p "${WORKTREE_DIR}/.factory/runs"
  cp -r "$RUN_DIR" "${WORKTREE_DIR}/.factory/runs/${RUN_ID}"

  # Write active-run pointer in the worktree
  printf '%s' "$RUN_ID" > "${WORKTREE_DIR}/.factory/active-run"

  # Record worktree path in source run dir
  printf '%s' "$WORKTREE_DIR" > "${RUN_DIR}/worktree"

  printf '  Worktree ready: %s\n' "$WORKTREE_DIR"
}

# ---------------------------------------------------------------------------
# Review phase — runs after author completes
# ---------------------------------------------------------------------------

# Run a single reviewer. Args: skill-name system-prompt review-prompt run-dir run-id
# Writes result to a temp file for the caller to check.
run_single_reviewer() {
  REVIEWER_NAME="$1"
  REVIEWER_SYSTEM="$2"
  REVIEWER_PROMPT="$3"
  REVIEWER_RUN_DIR="$4"
  REVIEWER_RESULT_FILE="$5"

  # Run from the project root so relative paths in prompts resolve correctly.
  # Each reviewer runs in a background subshell, so cd is isolated.
  cd "${REVIEWER_RUN_DIR%/.factory/runs/*}"

  REVIEWER_TRANSCRIPT="${REVIEWER_RUN_DIR}/reviews/transcript-${REVIEWER_NAME}.jsonl"

  printf '  [%s] starting...\n' "$REVIEWER_NAME"

  set +e
  claude \
    --dangerously-skip-permissions \
    --model "$FACTORY_MODEL" \
    --verbose --output-format stream-json \
    --append-system-prompt "$REVIEWER_SYSTEM" \
    -p "$REVIEWER_PROMPT" > "$REVIEWER_TRANSCRIPT"
  REVIEWER_EXIT=$?
  set -e

  if [ "$REVIEWER_EXIT" -ne 0 ]; then
    printf '  [%s] session failed (exit %d), skipping\n' "$REVIEWER_NAME" "$REVIEWER_EXIT"
    printf 'pass' > "$REVIEWER_RESULT_FILE"
    return
  fi

  REVIEW_FILE="${REVIEWER_RUN_DIR}/reviews/review-${REVIEWER_NAME}.md"
  if [ ! -f "$REVIEW_FILE" ]; then
    printf '  [%s] no review artifact produced, skipping\n' "$REVIEWER_NAME"
    printf 'pass' > "$REVIEWER_RESULT_FILE"
    return
  fi

  VERDICT="$(grep -i '^Verdict:' "$REVIEW_FILE" | head -1 | sed 's/.*: *//' | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')"
  printf '  [%s] verdict: %s\n' "$REVIEWER_NAME" "$VERDICT"
  printf '%s' "$VERDICT" > "$REVIEWER_RESULT_FILE"
}

# Run reviewers in parallel. Returns 0 if all pass, 1 if any fail.
# Args: run-dir run-id [reviewer-filter] [mode]
# reviewer-filter: comma-separated names, or empty for all
# mode: "run-scoped" (default) or "full-codebase"
run_reviews() {
  REVIEW_RUN_DIR="$1"
  REVIEW_RUN_ID="$2"
  REVIEWER_FILTER="${3:-}"
  REVIEW_MODE="${4:-run-scoped}"

  mkdir -p "${REVIEW_RUN_DIR}/reviews"

  # Archive previous round's reviews if they exist
  REVIEW_ROUND=$((${REVIEW_ROUND:-0} + 1))
  if [ "$REVIEW_ROUND" -gt 1 ]; then
    PREV_ROUND=$((REVIEW_ROUND - 1))
    ARCHIVE_DIR="${REVIEW_RUN_DIR}/reviews/round-${PREV_ROUND}"
    mkdir -p "$ARCHIVE_DIR"
    for prev_review in "${REVIEW_RUN_DIR}/reviews"/review-*.md; do
      [ -f "$prev_review" ] && cp "$prev_review" "$ARCHIVE_DIR/"
    done
    for prev_transcript in "${REVIEW_RUN_DIR}/reviews"/transcript-*.jsonl; do
      [ -f "$prev_transcript" ] && mv "$prev_transcript" "$ARCHIVE_DIR/"
    done
  fi

  # Read scope if specified
  REVIEW_SCOPE_DETAIL="$(cat "${REVIEW_RUN_DIR}/scope" 2>/dev/null || true)"
  SCOPE_INSTRUCTION=""
  if [ -n "$REVIEW_SCOPE_DETAIL" ]; then
    SCOPE_INSTRUCTION=" Focus your review on: ${REVIEW_SCOPE_DETAIL}. Read surrounding context as needed, but concentrate your findings on these areas."
  fi

  printf '\n  === Review phase (run: %s, mode: %s) ===\n\n' "$REVIEW_RUN_ID" "$REVIEW_MODE"

  REVIEW_TMP="$(mktemp -d -t factory-review-XXXXXX)"
  REVIEW_PIDS=""

  for REVIEWER in documentation behaviors architecture skills tests; do
    # Apply filter
    if [ -n "$REVIEWER_FILTER" ] && ! echo "$REVIEWER_FILTER" | grep -q "$REVIEWER"; then
      continue
    fi

    # Load prompts from file
    PROMPT_FILE="${PROMPTS_DIR}/review-${REVIEWER}.md"
    if [ ! -f "$PROMPT_FILE" ]; then
      printf '  [%s] prompt file missing, skipping\n' "$REVIEWER"
      continue
    fi

    R_SYSTEM="$(prompt_section "$PROMPT_FILE" "system" | sed "s/{{RUN_ID}}/${REVIEW_RUN_ID}/g")"

    if [ "$REVIEW_MODE" = "full-codebase" ]; then
      R_PROMPT="$(prompt_section "$PROMPT_FILE" "full-codebase" | sed "s/{{RUN_ID}}/${REVIEW_RUN_ID}/g")"
    else
      R_PROMPT="$(prompt_section "$PROMPT_FILE" "run-scoped" | sed "s/{{RUN_ID}}/${REVIEW_RUN_ID}/g")"
    fi

    R_PROMPT="${R_PROMPT}${SCOPE_INSTRUCTION}"
    run_single_reviewer "$REVIEWER" "$R_SYSTEM" "$R_PROMPT" "$REVIEW_RUN_DIR" "${REVIEW_TMP}/${REVIEWER}" &
    REVIEW_PIDS="$REVIEW_PIDS $!"
  done

  # Wait for all, with timeout
  REVIEWER_TIMEOUT="${REVIEWER_TIMEOUT:-1800}" # 30 minutes
  REVIEW_START="$(date +%s)"
  while true; do
    REVIEW_ALL_DONE=1
    for pid in $REVIEW_PIDS; do
      kill -0 "$pid" 2>/dev/null && REVIEW_ALL_DONE=0
    done
    [ "$REVIEW_ALL_DONE" = 1 ] && break
    REVIEW_ELAPSED="$(( $(date +%s) - REVIEW_START ))"
    if [ "$REVIEW_ELAPSED" -ge "$REVIEWER_TIMEOUT" ]; then
      for pid in $REVIEW_PIDS; do
        kill "$pid" 2>/dev/null || true
      done
      printf '  Reviewers timed out after %ds\n' "$REVIEW_ELAPSED"
      break
    fi
    sleep 2
  done

  # Check results
  REVIEW_FAILED=0
  for result_file in "${REVIEW_TMP}"/*; do
    [ -f "$result_file" ] || continue
    RESULT="$(cat "$result_file")"
    case "$RESULT" in
      pass) ;;
      fail|uncertain) REVIEW_FAILED=1 ;;
    esac
  done

  rm -rf "$REVIEW_TMP"
  return "$REVIEW_FAILED"
}

# ---------------------------------------------------------------------------
# Subcommand: run — autonomous session loop
# ---------------------------------------------------------------------------

cmd_run() {
  # Parse run-specific options
  RUN_ID=""
  BACKEND="local"
  NO_SANDBOX=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --run-id)
        RUN_ID="$2"
        shift 2
        ;;
      --backend)
        BACKEND="$2"
        shift 2
        ;;
      --no-sandbox)
        NO_SANDBOX=1
        shift
        ;;
      --)
        shift
        break
        ;;
      *)
        break
        ;;
    esac
  done

  case "$BACKEND" in
    local)
      if [ "$NO_SANDBOX" = 1 ]; then
        cmd_run_bare "$@"
      else
        cmd_run_local "$@"
      fi
      return
      ;;
    fargate)
      cmd_run_fargate "$@"
      return
      ;;
    *)
      die "Unknown backend '$BACKEND'. Available: local, fargate."
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Run report — generated at completion
# ---------------------------------------------------------------------------

generate_report() {
  REPORT_FILE="${RUN_DIR}/report.md"
  BRIEF_SUMMARY=""
  if [ -f "${RUN_DIR}/brief.md" ]; then
    BRIEF_SUMMARY="$(grep -v '^#' "${RUN_DIR}/brief.md" | grep -v '^$' | head -3)"
  fi

  {
    printf '# Run Report\n\n'
    printf 'Run: %s\n' "$RUN_ID"
    printf 'Status: %s\n' "$(cat "${RUN_DIR}/status" 2>/dev/null || echo "unknown")"
    printf 'Mode: %s\n' "$(cat "${RUN_DIR}/mode" 2>/dev/null || echo "build")"
    printf 'Sessions: %d\n\n' "${SESSION_COUNT:-0}"

    printf '## Brief\n\n'
    if [ -n "$BRIEF_SUMMARY" ]; then
      printf '%s\n\n' "$BRIEF_SUMMARY"
    else
      printf '(no brief)\n\n'
    fi

    printf '## Reviewer verdicts\n\n'
    if [ -d "${RUN_DIR}/reviews" ]; then
      for review in "${RUN_DIR}/reviews"/review-*.md; do
        [ -f "$review" ] || continue
        REVIEWER_NAME="$(basename "$review" .md | sed 's/^review-//')"
        VERDICT="$(grep -i '^Verdict:' "$review" | head -1 | sed 's/.*: *//')"
        printf '%s\n' "- **${REVIEWER_NAME}**: ${VERDICT:-no verdict}"
      done
      printf '\n'
    else
      printf '(no reviews)\n\n'
    fi

    printf '## Key findings\n\n'
    if [ -d "${RUN_DIR}/reviews" ]; then
      FINDING_COUNT=0
      for review in "${RUN_DIR}/reviews"/review-*.md; do
        [ -f "$review" ] || continue
        # Count numbered findings
        COUNT="$(grep -c '^[0-9]' "$review" 2>/dev/null || true)"
        FINDING_COUNT=$((FINDING_COUNT + ${COUNT:-0}))
      done
      if [ "$FINDING_COUNT" -gt 0 ]; then
        printf 'Reviewers produced findings. See reviews/ for details.\n\n'
      else
        printf 'No findings.\n\n'
      fi
    else
      printf '(no reviews)\n\n'
    fi

    printf '## Artifacts\n\n'
    for artifact in brief.md behaviors.diff.md approach.md plan.md; do
      [ -f "${RUN_DIR}/${artifact}" ] && printf '%s\n' "- ${artifact}"
    done
    printf '\n'

    printf '## Commits\n\n'
    WORKTREE_ROOT="${RUN_DIR%/.factory/runs/*}"
    if git -C "$WORKTREE_ROOT" rev-parse --git-dir > /dev/null 2>&1; then
      SOURCE_BR="$(cat "${RUN_DIR}/source-branch" 2>/dev/null || echo "main")"
      git -C "$WORKTREE_ROOT" log --oneline "${SOURCE_BR}..HEAD" 2>/dev/null | \
        while IFS= read -r line; do printf '%s\n' "- ${line}"; done
      printf '\n'
    else
      printf '(no git repo)\n\n'
    fi

    printf '## Sessions\n\n'
    if [ -f "${RUN_DIR}/sessions.log" ]; then
      cat "${RUN_DIR}/sessions.log"
      printf '\n'
    else
      printf '(no session log)\n\n'
    fi
  } > "$REPORT_FILE"

  printf '  Report written to %s\n' "$REPORT_FILE"
}

# ---------------------------------------------------------------------------
# Session loop (shared across backends)
# ---------------------------------------------------------------------------

# Run the session loop. The caller sets RUN_DIR, RUN_ID, and defines
# a launch_author function that takes a prompt and runs the author.
# The caller also sets PRE_SESSION_HOOK (optional) for per-session
# setup like credential refresh.
run_session_loop() {
  MAX_SESSIONS=50

  # Detect run mode
  RUN_MODE="$(cat "${RUN_DIR}/mode" 2>/dev/null || echo "build")"
  REVIEWER_FILTER="$(cat "${RUN_DIR}/reviewers" 2>/dev/null || true)"

  # Set status to executing if starting fresh
  CURRENT_STATUS="$(cat "${RUN_DIR}/status" 2>/dev/null || true)"
  if [ "$CURRENT_STATUS" = "planned" ]; then
    printf 'executing' > "${RUN_DIR}/status"
  fi

  # For review runs, start by running reviewers to get initial findings
  if [ "$RUN_MODE" = "review" ]; then
    printf '  Mode: review (reviewers run first)\n'
    REVIEW_SCOPE="full-codebase"
    if ! run_reviews "$RUN_DIR" "$RUN_ID" "$REVIEWER_FILTER" "$REVIEW_SCOPE"; then
      INITIAL_PROMPT="This is a review run. Reviewers have produced findings. Read the review artifacts at .factory/runs/${RUN_ID}/reviews/ and address the findings. When done, write status 'complete'."
    else
      printf '\n  All reviewers passed — nothing to fix.\n'
      printf 'complete' > "${RUN_DIR}/status"
      generate_report
      printf '\n  Run %s completed.\n' "$RUN_ID"
      return
    fi
  else
    INITIAL_PROMPT="Read the brief at .factory/runs/${RUN_ID}/brief.md and begin working."
    if [ -f "${RUN_DIR}/handoff.md" ]; then
      INITIAL_PROMPT="Read the handoff at .factory/runs/${RUN_ID}/handoff.md and continue working."
    fi
  fi

  SESSION_COUNT=0
  REVIEW_ROUND=0
  CONSECUTIVE_FAILURES=0
  SESSION_LOG="${RUN_DIR}/sessions.log"
  while true; do
    SESSION_COUNT=$((SESSION_COUNT + 1))
    printf '\n  === Session %d (run: %s) ===\n\n' "$SESSION_COUNT" "$RUN_ID"

    if [ "$SESSION_COUNT" -gt "$MAX_SESSIONS" ]; then
      printf '  Max sessions (%d) reached — stopping.\n' "$MAX_SESSIONS"
      printf 'failed' > "${RUN_DIR}/status"
      break
    fi

    # Per-session hook (credential refresh for local backend)
    if [ -n "${PRE_SESSION_HOOK:-}" ]; then
      eval "$PRE_SESSION_HOOK"
    fi

    # Build prompt
    if [ "$SESSION_COUNT" -eq 1 ]; then
      PROMPT="$INITIAL_PROMPT"
    else
      PROMPT="Continue from the handoff at .factory/runs/${RUN_ID}/handoff.md"
    fi

    # Set up transcript capture
    SESSION_DIR="${RUN_DIR}/sessions/session-${SESSION_COUNT}"
    mkdir -p "$SESSION_DIR"
    TRANSCRIPT_FILE="${SESSION_DIR}/transcript.jsonl"
    export FACTORY_TRANSCRIPT_FILE="$TRANSCRIPT_FILE"

    SESSION_START="$(date +%s)"

    # Launch author via caller-defined function
    set +e
    launch_author "$PROMPT" "$@"
    AUTHOR_EXIT=$?
    set -e

    SESSION_ELAPSED="$(( $(date +%s) - SESSION_START ))"
    printf '\n  Author exited (code: %d, %ds)\n' "$AUTHOR_EXIT" "$SESSION_ELAPSED"

    # Write session metadata
    STATUS_AFTER="$(cat "${RUN_DIR}/status" 2>/dev/null || echo "unknown")"
    printf 'session=%d exit=%d duration=%ds status=%s\n' \
      "$SESSION_COUNT" "$AUTHOR_EXIT" "$SESSION_ELAPSED" "$STATUS_AFTER" \
      >> "$SESSION_LOG"

    # Track consecutive failures
    if [ "$AUTHOR_EXIT" -ne 0 ]; then
      CONSECUTIVE_FAILURES=$((CONSECUTIVE_FAILURES + 1))
      if [ "$CONSECUTIVE_FAILURES" -ge 3 ]; then
        printf '  %d consecutive failures — stopping.\n' "$CONSECUTIVE_FAILURES"
        printf 'failed' > "${RUN_DIR}/status"
        break
      fi
    else
      CONSECUTIVE_FAILURES=0
    fi


    # Read status and decide
    STATUS="$(cat "${RUN_DIR}/status" 2>/dev/null || echo "unknown")"
    printf '  Run status: %s\n' "$STATUS"

    case "$STATUS" in
      complete)
        REVIEW_ROUND=$((REVIEW_ROUND + 1))
        if [ "$REVIEW_ROUND" -gt 10 ]; then
          printf '  Max review rounds (10) reached — accepting current state.\n'
          generate_report
          printf '\n  Run %s completed (review limit).\n' "$RUN_ID"
          break
        fi
        REVIEW_SCOPE="run-scoped"
        [ "$RUN_MODE" = "review" ] && REVIEW_SCOPE="full-codebase"
        if run_reviews "$RUN_DIR" "$RUN_ID" "$REVIEWER_FILTER" "$REVIEW_SCOPE"; then
          generate_report
          printf '\n  Run %s completed.\n' "$RUN_ID"
          break
        else
          printf '  Review returned findings — restarting author...\n'
          printf 'executing' > "${RUN_DIR}/status"
          PROMPT="Reviewers found issues. Read the review artifacts at .factory/runs/${RUN_ID}/reviews/ and address the findings."
          sleep 2
        fi
        ;;
      needs-user)
        printf '\n  Run %s needs your input.\n' "$RUN_ID"
        if [ -f "${RUN_DIR}/handoff.md" ]; then
          printf '  See: %s/handoff.md\n' "$RUN_DIR"
        fi
        break
        ;;
      failed)
        printf '\n  Run %s failed.\n' "$RUN_ID"
        if [ -f "${RUN_DIR}/handoff.md" ]; then
          printf '  See: %s/handoff.md\n' "$RUN_DIR"
        fi
        break
        ;;
      executing)
        printf '  Restarting session...\n'
        sleep 2
        ;;
      rate-limited)
        printf '  Rate limited — waiting 5 minutes...\n'
        sleep 300
        ;;
      *)
        printf '  Unexpected status "%s" — stopping.\n' "$STATUS"
        break
        ;;
    esac
  done

  printf '\n  Total sessions: %d\n' "$SESSION_COUNT"
}

# ---------------------------------------------------------------------------
# Run: local backend
# ---------------------------------------------------------------------------

cmd_run_local() {
  SOURCE_ROOT="${SANDBOX_ROOT:-$(pwd)}"

  setup_sandbox
  inject_credentials
  setup_git_signing
  setup_proxy
  setup_agent_browser

  # Resolve run and create worktree
  resolve_run_id "$SOURCE_ROOT"
  setup_run_worktree "$SOURCE_ROOT"

  # Record runtime in source run dir
  printf 'local' > "${RUN_DIR}/runtime"
  printf '%s' "$$" > "${RUN_DIR}/handle"

  # Sandbox root must include the git directory — worktrees reference
  # the main repo's .git via a relative path. Use the parent of the
  # worktree (the factory workspace) as the sandbox root.
  SANDBOX_ROOT="$(cd "$WORKTREE_DIR/.." && pwd)"
  RUN_DIR="${WORKTREE_DIR}/.factory/runs/${RUN_ID}"

  # Re-render sandbox profile for the worktree path
  cat "$COMMON_PROFILE" "$PROFILE_TEMPLATE" | sed \
    -e "s|_HOME_|$HOME|g" \
    -e "s|_SANDBOX_ROOT_|$SANDBOX_ROOT|g" \
    > "$RENDERED_PROFILE"

  printf '  Factory           session loop (run: %s)\n' "$RUN_ID"
  printf '  Worktree          %s\n' "$WORKTREE_DIR"

  # Disable commit signing in worktree so agents can commit without hardware key
  git -C "$WORKTREE_DIR" config commit.gpgsign false

  # Run from worktree so relative paths in agent prompts resolve correctly
  cd "$WORKTREE_DIR"

  # Define how this backend launches the author
  launch_author() {
    LAUNCH_PROMPT="$1"; shift
    sandbox-exec -f "$RENDERED_PROFILE" claude \
      --dangerously-skip-permissions \
      --model "$FACTORY_MODEL" \
      --verbose --output-format stream-json \
      --append-system-prompt "$FACTORY_SYSTEM_PROMPT" \
      -p "$LAUNCH_PROMPT" \
      "$@" | tee "$FACTORY_TRANSCRIPT_FILE"
  }

  # Refresh credentials before each session
  PRE_SESSION_HOOK='printf "  Refreshing credentials...\n"; claude -p "ok" --max-turns 1 > /dev/null 2>&1 || true; inject_credentials'

  run_session_loop "$@"
}

# ---------------------------------------------------------------------------
# Run: bare (no sandbox, for Fargate or Linux)
# ---------------------------------------------------------------------------

cmd_run_bare() {
  SEARCH_ROOT="${SANDBOX_ROOT:-$(pwd)}"

  resolve_run_id "$SEARCH_ROOT"

  # Create worktree if we're in a git repo (local --no-sandbox).
  # On Fargate, there's no git repo — the entrypoint handles workspace setup.
  if git -C "$SEARCH_ROOT" rev-parse --git-dir > /dev/null 2>&1; then
    setup_run_worktree "$SEARCH_ROOT"
    RUN_DIR="${WORKTREE_DIR}/.factory/runs/${RUN_ID}"
    SEARCH_ROOT="$WORKTREE_DIR"
    # Disable commit signing in worktree so agents can commit without hardware key
    git -C "$WORKTREE_DIR" config commit.gpgsign false

    # Run from worktree so relative paths in agent prompts resolve correctly
    cd "$WORKTREE_DIR"

    printf 'factory: bare session loop (run: %s)\n' "$RUN_ID"
    printf '  Worktree          %s\n' "$WORKTREE_DIR"
  else
    printf 'factory: bare session loop (run: %s)\n' "$RUN_ID"
  fi

  # Define how this backend launches the author
  launch_author() {
    LAUNCH_PROMPT="$1"; shift
    claude \
      --dangerously-skip-permissions \
      --model "$FACTORY_MODEL" \
      --verbose --output-format stream-json \
      --append-system-prompt "$FACTORY_SYSTEM_PROMPT" \
      -p "$LAUNCH_PROMPT" \
      "$@" | tee "$FACTORY_TRANSCRIPT_FILE"
  }

  # No per-session hook in bare mode
  PRE_SESSION_HOOK=""

  run_session_loop "$@"
}

# ---------------------------------------------------------------------------
# Run: Fargate backend
# ---------------------------------------------------------------------------

# Fargate config — override via environment or config file
FACTORY_CLUSTER="${FACTORY_CLUSTER:-}"
FACTORY_RUN_TASK="${FACTORY_RUN_TASK:-}"
FACTORY_S3_BUCKET="${FACTORY_S3_BUCKET:-}"
FACTORY_SUBNETS="${FACTORY_SUBNETS:-}"
FACTORY_SECURITY_GROUP="${FACTORY_SECURITY_GROUP:-}"
FACTORY_REGION="${FACTORY_REGION:-${AWS_DEFAULT_REGION:-us-west-1}}"

load_fargate_config() {
  FARGATE_CFG="${FACTORY_CONFIG}/fargate.env"
  if [ -f "$FARGATE_CFG" ]; then
    # Source config (KEY=VALUE lines)
    set -a
    . "$FARGATE_CFG"
    set +a
  fi

  [ -n "$FACTORY_CLUSTER" ] || die "FACTORY_CLUSTER not set. Run infrastructure/setup.sh or set in ${FARGATE_CFG}"
  [ -n "$FACTORY_S3_BUCKET" ] || die "FACTORY_S3_BUCKET not set"
  [ -n "$FACTORY_SUBNETS" ] || die "FACTORY_SUBNETS not set"
  [ -n "$FACTORY_SECURITY_GROUP" ] || die "FACTORY_SECURITY_GROUP not set"
}

cmd_run_fargate() {
  load_fargate_config

  SOURCE_ROOT="${SANDBOX_ROOT:-$(pwd)}"

  # Resolve run and create worktree
  resolve_run_id "$SOURCE_ROOT"
  setup_run_worktree "$SOURCE_ROOT"

  printf '  Factory           fargate run (run: %s)\n' "$RUN_ID"

  # Get Claude auth token
  inject_credentials
  [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ] || die "No Claude auth token available"

  # Upload worktree to S3
  printf '  Uploading worktree to S3...\n'
  tar cf - -C "$WORKTREE_DIR" . | \
    aws s3 cp \
      --region "$FACTORY_REGION" \
      - "s3://${FACTORY_S3_BUCKET}/runs/${RUN_ID}/workspace-in.tar"

  # Start run task
  printf '  Starting Fargate task...\n'
  TASK_ARN="$(aws ecs run-task \
    --region "$FACTORY_REGION" \
    --cluster "$FACTORY_CLUSTER" \
    --task-definition "${FACTORY_RUN_TASK:-factory-run}" \
    --launch-type FARGATE \
    --enable-execute-command \
    --network-configuration "awsvpcConfiguration={subnets=[${FACTORY_SUBNETS}],securityGroups=[${FACTORY_SECURITY_GROUP}],assignPublicIp=ENABLED}" \
    --overrides "{
      \"containerOverrides\": [{
        \"name\": \"run\",
        \"environment\": [
          {\"name\": \"FACTORY_RUN_ID\", \"value\": \"${RUN_ID}\"},
          {\"name\": \"FACTORY_S3_BUCKET\", \"value\": \"${FACTORY_S3_BUCKET}\"},
          {\"name\": \"FACTORY_REGION\", \"value\": \"${FACTORY_REGION}\"},
          {\"name\": \"CLAUDE_CODE_OAUTH_TOKEN\", \"value\": \"${CLAUDE_CODE_OAUTH_TOKEN}\"}
        ]
      }]
    }" \
    --query 'tasks[0].taskArn' \
    --output text)"

  printf '  Task: %s\n' "$TASK_ARN"

  # Record runtime and handle in source run dir
  printf 'fargate' > "${RUN_DIR}/runtime"
  printf '%s' "$TASK_ARN" > "${RUN_DIR}/handle"

  printf '  Run is executing on Fargate.\n'
  printf '  Worktree: %s\n' "$WORKTREE_DIR"
  printf '  Use "factory status" to check progress.\n'
  printf '  Use "factory shell" to attach to the running session.\n'
  printf '  Use "factory pull" to retrieve results.\n'
}

# ---------------------------------------------------------------------------
# Subcommand: pull — download completed workspace from S3
# ---------------------------------------------------------------------------

cmd_pull() {
  RUN_ID="${1:-}"
  SEARCH_ROOT="$(pwd)"
  FACTORY_RUNS="${SEARCH_ROOT}/.factory/runs"

  if [ -z "$RUN_ID" ]; then
    # Find a fargate run that's complete (check S3 or local status)
    if [ -d "$FACTORY_RUNS" ]; then
      for dir in "$FACTORY_RUNS"/*/; do
        [ -d "$dir" ] || continue
        backend="$(cat "${dir}backend" 2>/dev/null || true)"
        if [ "$backend" = "fargate" ]; then
          RUN_ID="$(basename "$dir")"
          break
        fi
      done
    fi
    [ -n "$RUN_ID" ] || die "No fargate run found."
  fi

  load_fargate_config

  RUN_DIR="${FACTORY_RUNS}/${RUN_ID}"
  WORKTREE_PATH="$(cat "${RUN_DIR}/worktree" 2>/dev/null || true)"

  if [ -z "$WORKTREE_PATH" ] || [ ! -d "$WORKTREE_PATH" ]; then
    # Worktree doesn't exist locally — extract to project-root/RUN_ID
    PROJECT_ROOT="$(cd "$SEARCH_ROOT/.." && pwd)"
    WORKTREE_PATH="${PROJECT_ROOT}/${RUN_ID}"
    mkdir -p "$WORKTREE_PATH"
  fi

  printf '  Downloading workspace for run %s...\n' "$RUN_ID"
  printf '  Target: %s\n' "$WORKTREE_PATH"
  aws s3 cp \
    --region "$FACTORY_REGION" \
    "s3://${FACTORY_S3_BUCKET}/runs/${RUN_ID}/workspace.tar" \
    - | tar xf - -C "$WORKTREE_PATH"

  printf '  Workspace downloaded to %s\n' "$WORKTREE_PATH"
}

# ---------------------------------------------------------------------------
# Subcommand: shell — interactive shell into running task
# ---------------------------------------------------------------------------

cmd_shell() {
  RUN_ID="${1:-}"
  SEARCH_ROOT="$(pwd)"

  resolve_run_id "$SEARCH_ROOT"
  load_fargate_config

  TASK_ARN="$(cat "${RUN_DIR}/handle" 2>/dev/null || true)"
  [ -n "$TASK_ARN" ] || die "No task handle found for run $RUN_ID"

  printf '  Connecting to run %s...\n' "$RUN_ID"
  aws ecs execute-command \
    --region "$FACTORY_REGION" \
    --cluster "$FACTORY_CLUSTER" \
    --task "$TASK_ARN" \
    --container run \
    --command "/bin/bash" \
    --interactive
}

# ---------------------------------------------------------------------------
# Subcommand: watch — poll status and notify on change
# ---------------------------------------------------------------------------

cmd_watch() {
  INTERVAL="${1:-60}"
  SEARCH_ROOT="$(pwd)"
  LAST_STATUS=""

  printf '  Watching factory runs (every %ds)...\n' "$INTERVAL"
  printf '  Press Ctrl+C to stop.\n\n'

  while true; do
    CURRENT="$(cmd_status "$SEARCH_ROOT" 2>/dev/null || true)"

    if [ "$CURRENT" != "$LAST_STATUS" ] && [ -n "$LAST_STATUS" ]; then
      # Status changed — notify
      CHANGED_RUN=""
      CHANGED_STATUS=""
      FACTORY_RUNS="${SEARCH_ROOT}/.factory/runs"
      if [ -d "$FACTORY_RUNS" ]; then
        for dir in "$FACTORY_RUNS"/*/; do
          [ -d "$dir" ] || continue
          s="$(cat "${dir}status" 2>/dev/null || true)"
          case "$s" in
            complete|needs-user|failed)
              CHANGED_RUN="$(basename "$dir")"
              CHANGED_STATUS="$s"
              break
              ;;
          esac
        done
      fi

      if [ -n "$CHANGED_RUN" ]; then
        RUN_DIR="${FACTORY_RUNS}/${CHANGED_RUN}"
        NOTIFY_BODY="${CHANGED_RUN}: ${CHANGED_STATUS}"

        # Append brief summary
        if [ -f "${RUN_DIR}/brief.md" ]; then
          BRIEF_LINE="$(head -5 "${RUN_DIR}/brief.md" | grep -v '^#' | grep -v '^$' | head -1 | cut -c1-50)"
          [ -n "$BRIEF_LINE" ] && NOTIFY_BODY="${NOTIFY_BODY}
${BRIEF_LINE}"
        fi

        # Status-specific details
        case "$CHANGED_STATUS" in
          complete)
            SESSION_COUNT=0
            if [ -d "${RUN_DIR}/sessions" ]; then
              SESSION_COUNT="$(find "${RUN_DIR}/sessions" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')"
            fi
            if [ "$SESSION_COUNT" -gt 0 ]; then
              NOTIFY_BODY="${NOTIFY_BODY}
${SESSION_COUNT} sessions"
            fi
            if [ -d "${RUN_DIR}/reviews" ]; then
              ALL_PASS=true
              FOUND_REVIEW=false
              for review_file in "${RUN_DIR}/reviews"/review-*.md; do
                [ -f "$review_file" ] || continue
                FOUND_REVIEW=true
                verdict="$(grep -i '^verdict:' "$review_file" 2>/dev/null | head -1 | sed 's/^[Vv]erdict:[[:space:]]*//' | tr '[:upper:]' '[:lower:]')"
                if [ "$verdict" != "pass" ]; then
                  ALL_PASS=false
                fi
              done
              if [ "$FOUND_REVIEW" = true ]; then
                if [ "$ALL_PASS" = true ]; then
                  NOTIFY_BODY="${NOTIFY_BODY}, reviews passed"
                else
                  NOTIFY_BODY="${NOTIFY_BODY}, reviews failed"
                fi
              fi
            fi
            ;;
          needs-user)
            if [ -f "${RUN_DIR}/handoff.md" ]; then
              NEED="$(sed -n '/^#.*[Oo]pen [Qq]uestion/,/^#/{/^#/d;/^$/d;s/^- //;p;}' "${RUN_DIR}/handoff.md" | head -1 | cut -c1-80)"
              [ -n "$NEED" ] && NOTIFY_BODY="${NOTIFY_BODY}
${NEED}"
            fi
            ;;
        esac

        # macOS notification
        if command -v osascript >/dev/null 2>&1; then
          ESCAPED_BODY="$(printf '%s' "$NOTIFY_BODY" | sed 's/\\/\\\\/g;s/"/\\"/g')"
          osascript -e "display notification \"${ESCAPED_BODY}\" with title \"Factory\""
        elif command -v terminal-notifier >/dev/null 2>&1; then
          terminal-notifier -title "Factory" -message "$NOTIFY_BODY"
        fi
        printf '  [NOTIFY] Run %s: %s\n' "$CHANGED_RUN" "$CHANGED_STATUS"
      fi
    fi

    LAST_STATUS="$CURRENT"
    printf '%s' "$CURRENT"
    printf '\n---\n'
    sleep "$INTERVAL"
  done
}

# ---------------------------------------------------------------------------
# Subcommand: status — show run state
# ---------------------------------------------------------------------------

cmd_status() {
  SEARCH_ROOT="${1:-$(pwd)}"
  FACTORY_RUNS="${SEARCH_ROOT}/.factory/runs"

  if [ ! -d "$FACTORY_RUNS" ]; then
    printf 'No runs found in %s\n' "$SEARCH_ROOT"
    exit 0
  fi

  # Load Fargate config if available (needed for ECS/S3 queries)
  FARGATE_CFG="${FACTORY_CONFIG}/fargate.env"
  if [ -f "$FARGATE_CFG" ]; then
    set -a; . "$FARGATE_CFG"; set +a
  fi

  printf '%-20s %-16s %-10s %s\n' "RUN" "STATUS" "RUNTIME" "BRIEF"
  printf '%-20s %-16s %-10s %s\n' "---" "------" "-------" "-----"

  for dir in "$FACTORY_RUNS"/*/; do
    [ -d "$dir" ] || continue
    run_id="$(basename "$dir")"
    status="$(cat "${dir}status" 2>/dev/null || echo "-")"
    runtime="$(cat "${dir}runtime" 2>/dev/null || echo "-")"

    # For Fargate runs, check remote state
    if [ "$runtime" = "fargate" ] && [ -n "${FACTORY_CLUSTER:-}" ]; then
      handle="$(cat "${dir}handle" 2>/dev/null || true)"
      if [ -n "$handle" ]; then
        # Check if completed workspace exists in S3
        if aws s3api head-object \
            --region "${FACTORY_REGION:-us-west-1}" \
            --bucket "$FACTORY_S3_BUCKET" \
            --key "runs/${run_id}/workspace.tar" \
            >/dev/null 2>&1; then
          status="complete (s3)"
        else
          # Check ECS task state
          task_status="$(aws ecs describe-tasks \
            --region "${FACTORY_REGION:-us-west-1}" \
            --cluster "$FACTORY_CLUSTER" \
            --tasks "$handle" \
            --query 'tasks[0].lastStatus' \
            --output text 2>/dev/null || echo "UNKNOWN")"
          case "$task_status" in
            RUNNING)    status="executing (ecs)" ;;
            STOPPED)    status="stopped (ecs)" ;;
            PROVISIONING|PENDING) status="starting (ecs)" ;;
            UNKNOWN)    ;; # keep local status
          esac
        fi
      fi
    fi

    # Extract first line of brief for summary
    brief="-"
    if [ -f "${dir}brief.md" ]; then
      brief="$(head -5 "${dir}brief.md" | grep -v '^#' | grep -v '^$' | head -1 | cut -c1-50)"
      [ -z "$brief" ] && brief="(brief exists)"
    fi

    printf '%-20s %-16s %-10s %s\n' "$run_id" "$status" "$runtime" "$brief"
  done
}

# ---------------------------------------------------------------------------
# Subcommand: resume — restart a paused run
# ---------------------------------------------------------------------------

cmd_resume() {
  RUN_ID="$1"
  SEARCH_ROOT="$(pwd)"
  FACTORY_RUNS="${SEARCH_ROOT}/.factory/runs"

  if [ -z "$RUN_ID" ]; then
    # Find a run that needs the user or failed
    if [ -d "$FACTORY_RUNS" ]; then
      for dir in "$FACTORY_RUNS"/*/; do
        [ -d "$dir" ] || continue
        if [ -f "${dir}status" ]; then
          s="$(cat "${dir}status" 2>/dev/null || true)"
          if [ "$s" = "needs-user" ] || [ "$s" = "failed" ]; then
            RUN_ID="$(basename "$dir")"
            break
          fi
        fi
      done
    fi
    [ -n "$RUN_ID" ] || die "No run found needing resume."
  fi

  RUN_DIR="${FACTORY_RUNS}/${RUN_ID}"
  [ -d "$RUN_DIR" ] || die "Run directory not found: $RUN_DIR"

  printf '  Resuming run %s\n' "$RUN_ID"

  # Launch an interactive session so the user can provide input
  setup_sandbox
  inject_credentials
  setup_git_signing
  setup_proxy
  setup_agent_browser

  printf '  Factory           resume session (run: %s)\n' "$RUN_ID"
  launch_author "$@"
}

# ---------------------------------------------------------------------------
# Subcommand: land — rebase, merge, capture artifacts, clean up
# ---------------------------------------------------------------------------

# Artifacts to copy from worktree run dir back to source run dir.
LAND_ARTIFACTS="sessions sessions.log reviews report.md status"

cmd_land() {
  RUN_ID="${1:-}"
  SEARCH_ROOT="$(pwd)"
  FACTORY_RUNS="${SEARCH_ROOT}/.factory/runs"

  if [ -z "$RUN_ID" ]; then
    # Find the most recent complete run
    if [ -d "$FACTORY_RUNS" ]; then
      for dir in "$FACTORY_RUNS"/*/; do
        [ -d "$dir" ] || continue
        if [ -f "${dir}status" ]; then
          s="$(cat "${dir}status" 2>/dev/null || true)"
          if [ "$s" = "complete" ]; then
            RUN_ID="$(basename "$dir")"
          fi
        fi
      done
    fi
    [ -n "$RUN_ID" ] || die "No complete run found to land."
  fi

  RUN_DIR="${FACTORY_RUNS}/${RUN_ID}"
  [ -d "$RUN_DIR" ] || die "Run directory not found: $RUN_DIR"

  # Verify status is complete
  STATUS="$(cat "${RUN_DIR}/status" 2>/dev/null || true)"
  [ "$STATUS" = "complete" ] || die "Run $RUN_ID has status '$STATUS', expected 'complete'"

  # Verify reviews passed (if any)
  if [ -d "${RUN_DIR}/reviews" ]; then
    for review_file in "${RUN_DIR}/reviews"/review-*.md; do
      [ -f "$review_file" ] || continue
      verdict="$(grep -i '^verdict:' "$review_file" 2>/dev/null | head -1 | sed 's/^[Vv]erdict:[[:space:]]*//' | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')"
      if [ -z "$verdict" ]; then
        die "Cannot land run $RUN_ID: review $(basename "$review_file") has no verdict"
      fi
      if [ "$verdict" != "pass" ]; then
        die "Cannot land run $RUN_ID: review $(basename "$review_file") has verdict '$verdict'"
      fi
    done
  fi

  # Read worktree path
  WORKTREE_PATH="$(cat "${RUN_DIR}/worktree" 2>/dev/null || true)"
  [ -n "$WORKTREE_PATH" ] || die "No worktree path recorded for run $RUN_ID"
  [ -d "$WORKTREE_PATH" ] || die "Worktree directory does not exist: $WORKTREE_PATH"

  printf '  Landing run %s...\n' "$RUN_ID"

  # Copy artifacts from worktree run dir back to source run dir
  WT_RUN_DIR="${WORKTREE_PATH}/.factory/runs/${RUN_ID}"
  if [ -d "$WT_RUN_DIR" ]; then
    for artifact in $LAND_ARTIFACTS; do
      src="${WT_RUN_DIR}/${artifact}"
      dst="${RUN_DIR}/${artifact}"
      if [ -d "$src" ]; then
        cp -r "$src" "$dst"
      elif [ -f "$src" ]; then
        cp "$src" "$dst"
      fi
    done
    printf '  Artifacts copied.\n'
  fi

  # Read source branch
  SOURCE_BRANCH="$(cat "${RUN_DIR}/source-branch" 2>/dev/null || echo "main")"

  # Remove worktree first — branch can't be rebased while checked out
  git -C "$SEARCH_ROOT" worktree remove --force "$WORKTREE_PATH" 2>/dev/null || true
  printf '  Worktree removed.\n'

  # Rebase onto source branch
  if ! git -C "$SEARCH_ROOT" rebase "$SOURCE_BRANCH" "$RUN_ID" 2>/dev/null; then
    git -C "$SEARCH_ROOT" rebase --abort 2>/dev/null || true
    die "Rebase failed — resolve conflicts manually"
  fi
  printf '  Rebased onto %s.\n' "$SOURCE_BRANCH"

  # Checkout source branch and fast-forward merge
  git -C "$SEARCH_ROOT" checkout "$SOURCE_BRANCH"
  if ! git -C "$SEARCH_ROOT" merge --ff-only "$RUN_ID"; then
    die "Fast-forward merge failed"
  fi
  printf '  Merged (fast-forward).\n'

  # Delete branch
  git -C "$SEARCH_ROOT" branch -d "$RUN_ID" 2>/dev/null || true
  printf '  Branch deleted.\n'

  # Update status
  printf 'landed' > "${RUN_DIR}/status"

  printf '  Run %s landed successfully.\n' "$RUN_ID"
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
  cat <<'EOF'
Usage: factory [SUBCOMMAND] [OPTIONS]

Subcommands:
  (none)              Launch an interactive sandboxed agent session
  run [OPTIONS]       Autonomous session loop
  status [PATH]       Show run state for a project
  watch [INTERVAL]    Poll status, notify on change (default: 60s)
  pull [RUN_ID]       Download completed workspace from S3 (fargate)
  shell [RUN_ID]      Interactive shell into running task (fargate)
  resume [RUN_ID]     Restart a paused or failed run
  land [RUN_ID]       Rebase, merge, capture artifacts, clean up

Run options:
  --run-id ID         Target a specific run
  --backend BACKEND   Execution backend: local (default), fargate

Global options:
  --sandbox-root DIR  Override the sandbox file-access root (default: pwd)
  --proxy-port N      Credential proxy port (default: 9121)
  --dry-run           Print the rendered sandbox profile and exit
  --force             Kill existing Claude Code processes before launching
  --logs              Tail the factory log file
  -h, --help          Show this help

Examples:
  factory                              # interactive session
  factory run                          # local session loop
  factory run --backend fargate        # run on Fargate
  factory status                       # show all runs
  factory watch                        # poll + notify on change
  factory pull                         # download fargate results
  factory shell                        # shell into running task
  factory resume                       # resume a paused run
  factory land                         # land the most recent complete run
  factory land RUN_ID                   # land a specific run
EOF
  exit 0
}

# ---------------------------------------------------------------------------
# Source guard — when sourced for testing, export functions only
# ---------------------------------------------------------------------------

if [ "${FACTORY_LIB:-}" = 1 ]; then
  return 0 2>/dev/null || exit 0
fi

# ---------------------------------------------------------------------------
# Global option pre-processing
# ---------------------------------------------------------------------------

# Handle global flags that can appear before or instead of a subcommand
SANDBOX_ROOT=""
DRY_RUN=0
FORCE_KILL=0

# Separate global options from subcommand + its args
ARGS=""
while [ $# -gt 0 ]; do
  case "$1" in
    --sandbox-root)
      SANDBOX_ROOT="$2"
      shift 2
      ;;
    --proxy-port)
      PROXY_PORT="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --force)
      FORCE_KILL=1
      shift
      ;;
    --logs)
      [ -f "$LOG_FILE" ] || die "No log file yet — run factory first"
      exec tail -f "$LOG_FILE"
      ;;
    -h|--help)
      usage
      ;;
    *)
      # First non-flag argument is the subcommand (or pass-through)
      break
      ;;
  esac
done

# Handle --force (kill existing Claude processes)
if [ "$FORCE_KILL" = 1 ]; then
  CC_PIDS="$(pgrep -f 'claude' 2>/dev/null || true)"
  if [ -n "$CC_PIDS" ]; then
    printf '  Stopping existing Claude Code process(es)...\n'
    for pid in $CC_PIDS; do
      kill "$pid" 2>/dev/null || true
    done
    WAITED=0
    while [ "$WAITED" -lt 6 ]; do
      REMAINING="$(pgrep -f 'claude' 2>/dev/null || true)"
      [ -z "$REMAINING" ] && break
      sleep 0.5
      WAITED=$((WAITED + 1))
    done
    REMAINING="$(pgrep -f 'claude' 2>/dev/null || true)"
    if [ -n "$REMAINING" ]; then
      for pid in $REMAINING; do
        kill -9 "$pid" 2>/dev/null || true
      done
      sleep 0.5
    fi
    REMAINING="$(pgrep -f 'claude' 2>/dev/null || true)"
    [ -n "$REMAINING" ] && die "Could not stop existing Claude Code (PIDs: $REMAINING)"
    printf '  Existing Claude Code stopped.\n'
  fi
fi

# Handle --dry-run
if [ "$DRY_RUN" = 1 ]; then
  setup_sandbox
  echo "--- Rendered Seatbelt profile ---"
  echo "HOME         = $HOME"
  echo "SANDBOX_ROOT = $SANDBOX_ROOT"
  echo "---------------------------------"
  cat "$RENDERED_PROFILE"
  rm -f "$RENDERED_PROFILE"
  RENDERED_PROFILE=""
  exit 0
fi

# ---------------------------------------------------------------------------
# Subcommand dispatch
# ---------------------------------------------------------------------------

SUBCOMMAND="${1:-}"

case "$SUBCOMMAND" in
  run)
    shift
    cmd_run "$@"
    ;;
  status)
    shift
    cmd_status "$@"
    ;;
  watch)
    shift
    cmd_watch "$@"
    ;;
  pull)
    shift
    cmd_pull "$@"
    ;;
  shell)
    shift
    cmd_shell "$@"
    ;;
  resume)
    shift
    cmd_resume "$@"
    ;;
  land)
    shift
    cmd_land "$@"
    ;;
  "")
    cmd_interactive "$@"
    ;;
  *)
    # Unknown subcommand — treat as args to interactive session
    cmd_interactive "$@"
    ;;
esac
